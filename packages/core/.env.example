# ── Frappe Backend ────────────────────────────────────────────────────────────
# Server-side only — never sent to the browser.
# Use FRAPPE_INTERNAL_URL when Frappe is on a private network (e.g. Docker).
FRAPPE_URL=http://localhost:8000
# FRAPPE_INTERNAL_URL=http://frappe:8000
# NEXT_PUBLIC_FRAPPE_SITE=yoursite.example.com

# ── Custom Apps ───────────────────────────────────────────────────────────────
# JSON array of PetalAppMeta objects. Add one entry per custom app.
# Example: PETAL_APPS=[{"name":"my-app","version":"0.0.1","url":"https://cdn.example.com/my-app/petal.hooks.js"}]
PETAL_APPS=[]

# ── Theme ─────────────────────────────────────────────────────────────────────
# JSON object with Partial<PetalTheme> overrides.
PETAL_THEME={"primaryColor":"#16a34a"}

# ── Multi-Tenancy ─────────────────────────────────────────────────────────────
# When set, PETAL_TENANTS enables multi-tenant mode. Each key is the incoming
# hostname; the value is the tenant's Frappe backend, custom apps, and theme.
# FRAPPE_URL / PETAL_APPS / PETAL_THEME above are ignored when this is set.
#
# PETAL_TENANTS={
#   "acme.example.com": {
#     "frappeUrl": "http://acme-frappe:8000",
#     "frappeSite": "acme.example.com",
#     "apps": [{"name":"acme-app","version":"0.0.1","url":"https://cdn.example.com/acme/petal.hooks.js"}],
#     "theme": {"primaryColor":"#2563eb"}
#   },
#   "beta.example.com": {
#     "frappeUrl": "http://beta-frappe:8000",
#     "apps": [],
#     "theme": {"primaryColor":"#dc2626"}
#   }
# }

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used in the /docs CORS hint page only.
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
